<script>
const I={
  down:`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>`,
  up:`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>`,
  trend:`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  btc:`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.767 19.089c4.924.868 6.14-6.025 1.216-6.894m-1.216 6.894L5.86 18.047m5.908 1.042-.347 1.97m1.563-8.864c4.924.869 6.14-6.025 1.215-6.893m-1.215 6.893-3.94-.694m5.155-6.2L8.29 5.411m5.908 1.042.348-1.97M7.48 20.364l3.126-17.727"/></svg>`,
  trash:`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>`,
  card:`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
  inbox:`<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/></svg>`,
  bars:`<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  list:`<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>`,
  gift2:`<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>`,
};

const KEY='moneyVault_v4';
let S={cashBalance:0,transactions:[],balanceHistory:[],giftCards:[],investments:{stockBalance:0,stockUpdated:null,btcAmount:0,btcUpdated:null,cachedBtcPrice:null,btcPriceAt:null},settings:{childName:'',notificationsEnabled:false}};
let activeGcId=null,successTimer=null;

function save(){localStorage.setItem(KEY,JSON.stringify(S))}
function load(){
  const raw=localStorage.getItem(KEY);
  if(raw){try{S=JSON.parse(raw)}catch(e){}}
  else{
    const old=localStorage.getItem('moneyVault_v3');
    if(old){try{const p=JSON.parse(old);S.cashBalance=p.cashBalance||0;S.transactions=(p.transactions||[]).filter(t=>t.type==='deposit'||t.type==='spend');S.balanceHistory=p.balanceHistory||[];S.giftCards=p.giftCards||[];S.settings=p.settings||S.settings;save()}catch(e){}}
  }
  if(!S.investments)S.investments={stockBalance:0,stockUpdated:null,btcAmount:0,btcUpdated:null,cachedBtcPrice:null,btcPriceAt:null};
  if(!S.balanceHistory)S.balanceHistory=[];
}
function saveSetting(k,v){S.settings[k]=v;save()}

const fc=c=>'$'+(c/100).toFixed(2);
const fu=n=>'$'+(+n).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
const fd=iso=>new Date(iso).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
const fdf=iso=>new Date(iso).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'});
const daysSince=iso=>iso?(Date.now()-new Date(iso).getTime())/86400000:Infinity;
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

function switchTab(t){
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  document.querySelector('[data-tab="'+t+'"]').classList.add('active');
  if(t==='home'){updateHome();drawChart()}
  if(t==='history')renderHistory();
  if(t==='giftcards')renderGcs();
  if(t==='invest')renderInvest();
  if(t==='spend')upSpend();
}

function updateUI(){
  const n=S.settings.childName;
  document.getElementById('hdrName').textContent=n?n+"'s Money Vault":'My Money Vault';
  document.getElementById('hdrAmt').textContent=fc(S.cashBalance);
  updateHome();drawChart();
}
function updateHome(){
  const gt=gcSum();
  document.getElementById('hCash').textContent=fc(S.cashBalance);
  document.getElementById('hGc').textContent=fc(gt);
  document.getElementById('hTotal').textContent=fc(S.cashBalance+gt);
  document.getElementById('chartBadge').textContent=fc(S.cashBalance);
  renderHomeRecent();renderHomeInvest();
}

function renderHomeRecent(){
  const el=document.getElementById('hRecent');
  if(!S.transactions.length){el.innerHTML='<div class="empty"><div class="empty-chip">'+I.inbox+'</div><div class="et">No transactions yet — start adding your money!</div></div>';return}
  el.innerHTML=S.transactions.slice(0,5).map(t=>txnHTML(t,false)).join('');
}

function txnHTML(t,showDelete){
  if(t.type==='invest-stock'||t.type==='invest-btc'){
    const isBtc=t.type==='invest-btc';
    const del=showDelete?'<br><button class="txn-del-btn" onclick="deleteTransaction('+t.id+')">'+I.trash+' Delete</button>':'';
    return '<div class="txn"><div class="txn-ico inv">'+(isBtc?I.btc:I.trend)+'</div><div class="txn-body"><div class="txn-note">'+esc(t.note)+'</div>'+(t.correction?'<div class="txn-cat" style="color:var(--amber)">Correction entry</div>':'')+'<div class="txn-date">'+fdf(t.date)+'</div></div><div class="txn-amt" style="color:var(--sky);font-size:.85em;text-align:right;flex-shrink:0">'+esc(t.value)+del+'</div></div>';
  }
  const p=t.type==='deposit';
  const del=showDelete?'<br><button class="txn-del-btn" onclick="deleteTransaction('+t.id+')">'+I.trash+' Delete</button>':'';
  return '<div class="txn"><div class="txn-ico '+(p?'d':'s')+'">'+(p?I.down:I.up)+'</div><div class="txn-body"><div class="txn-note">'+esc(t.note)+'</div>'+(t.cat?'<div class="txn-cat">'+esc(t.cat)+'</div>':'')+'<div class="txn-date">'+fdf(t.date)+'</div></div><div class="txn-amt '+(p?'p':'n')+'" style="text-align:right;flex-shrink:0">'+(p?'+':'-')+fc(t.amount)+del+'</div></div>';
}

function renderHomeInvest(){
  const el=document.getElementById('hInvest');
  const inv=S.investments;
  const bv=(inv.btcAmount&&inv.cachedBtcPrice)?inv.btcAmount*inv.cachedBtcPrice:0;
  const sv=inv.stockBalance/100,tot=sv+bv;
  if(!inv.stockBalance&&!inv.btcAmount){el.innerHTML='<div class="empty"><div class="empty-chip">'+I.bars+'</div><div class="et">No investments added yet</div></div>';return}
  let rows='';
  if(inv.stockBalance)rows+='<div class="inv-row"><div class="inv-row-left"><div class="inv-row-chip green">'+I.trend+'</div>Stock Portfolio</div><div class="inv-row-val" style="color:var(--forest)">'+fc(inv.stockBalance)+'</div></div>';
  if(inv.btcAmount)rows+='<div class="inv-row"><div class="inv-row-left"><div class="inv-row-chip amber">'+I.btc+'</div>Bitcoin ('+inv.btcAmount+' BTC)</div><div class="inv-row-val" style="color:var(--amber)">'+(bv?fu(bv):'—')+'</div></div>';
  rows+='<div class="inv-total-row"><span>Total Investments</span><span style="color:var(--sky)">'+(tot>0?fu(tot):'—')+'</span></div>';
  el.innerHTML=rows;
}

function pushHistory(bal){S.balanceHistory.push({date:new Date().toISOString(),balance:bal});if(S.balanceHistory.length>120)S.balanceHistory=S.balanceHistory.slice(-120)}
function drawChart(){
  const cv=document.getElementById('bchart');if(!cv)return;
  const dpr=window.devicePixelRatio||1,rect=cv.getBoundingClientRect();if(!rect.width)return;
  cv.width=rect.width*dpr;cv.height=rect.height*dpr;
  const ctx=cv.getContext('2d');ctx.scale(dpr,dpr);
  const W=rect.width,H=rect.height,data=S.balanceHistory;
  ctx.fillStyle='#f0f7f3';rrect(ctx,0,0,W,H,10);ctx.fill();
  if(data.length<2){ctx.fillStyle='#9ab8a5';ctx.font='600 13px Outfit,sans-serif';ctx.textAlign='center';ctx.fillText('Make your first deposit to see your chart grow!',W/2,H/2+4);document.getElementById('chartSub').style.display='block';return}
  document.getElementById('chartSub').style.display='none';
  const pad={t:28,r:22,b:26,l:22},cW=W-pad.l-pad.r,cH=H-pad.t-pad.b;
  const bals=data.map(d=>d.balance),minB=Math.min(...bals),maxB=Math.max(...bals),rng=(maxB-minB)||1;
  const pts=data.map((d,i)=>({x:pad.l+(i/(data.length-1))*cW,y:pad.t+cH-((d.balance-minB)/rng)*cH,b:d.balance,d:d.date}));
  ctx.strokeStyle='rgba(26,102,68,.07)';ctx.lineWidth=1;
  for(let i=0;i<=3;i++){const y=pad.t+(cH/3)*i;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);ctx.stroke()}
  const g=ctx.createLinearGradient(0,pad.t,0,pad.t+cH);g.addColorStop(0,'rgba(26,102,68,.2)');g.addColorStop(.7,'rgba(26,102,68,.04)');g.addColorStop(1,'rgba(26,102,68,0)');
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);
  for(let i=1;i<pts.length;i++){const cp=(pts[i-1].x+pts[i].x)/2;ctx.bezierCurveTo(cp,pts[i-1].y,cp,pts[i].y,pts[i].x,pts[i].y)}
  const lp=pts[pts.length-1];ctx.lineTo(lp.x,pad.t+cH);ctx.lineTo(pts[0].x,pad.t+cH);ctx.closePath();ctx.fillStyle=g;ctx.fill();
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);
  for(let i=1;i<pts.length;i++){const cp=(pts[i-1].x+pts[i].x)/2;ctx.bezierCurveTo(cp,pts[i-1].y,cp,pts[i].y,pts[i].x,pts[i].y)}
  ctx.strokeStyle='#1a6644';ctx.lineWidth=2.5;ctx.lineJoin='round';ctx.lineCap='round';ctx.stroke();
  pts.forEach(p=>{ctx.beginPath();ctx.arc(p.x,p.y,4.5,0,Math.PI*2);ctx.fillStyle='#fff';ctx.fill();ctx.strokeStyle='#1a6644';ctx.lineWidth=2;ctx.stroke()});
  ctx.font='700 11px Outfit,sans-serif';ctx.fillStyle='#1a6644';ctx.textAlign='left';ctx.fillText(fc(pts[0].b),pts[0].x,pts[0].y-9);
  ctx.textAlign=lp.x>W*.65?'right':'left';ctx.fillText(fc(lp.b),lp.x,lp.y-9);
  ctx.font='500 10px Outfit,sans-serif';ctx.fillStyle='#9ab8a5';ctx.textAlign='left';ctx.fillText(fd(data[0].date),pad.l,H-6);ctx.textAlign='right';ctx.fillText(fd(data[data.length-1].date),W-pad.r,H-6);
}
function rrect(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.arcTo(x+w,y,x+w,y+r,r);ctx.lineTo(x+w,y+h-r);ctx.arcTo(x+w,y+h,x+w-r,y+h,r);ctx.lineTo(x+r,y+h);ctx.arcTo(x,y+h,x,y+h-r,r);ctx.lineTo(x,y+r);ctx.arcTo(x,y,x+r,y,r);ctx.closePath()}

const DENOMS=[{id:'cP',v:1},{id:'cN',v:5},{id:'cD',v:10},{id:'cQ',v:25},{id:'cDC',v:100},{id:'cB1',v:100},{id:'cB5',v:500},{id:'cB10',v:1000},{id:'cB20',v:2000},{id:'cB50',v:5000},{id:'cB100',v:10000}];
function calcDep(){const t=DENOMS.reduce((s,d)=>s+(parseInt(document.getElementById(d.id).value)||0)*d.v,0);document.getElementById('depPreview').textContent=fc(t);return t}
function doDeposit(){const amt=calcDep();if(amt<=0){alert('Count at least some money first!');return}const note=document.getElementById('dNote').value.trim()||'Deposit';S.cashBalance+=amt;S.transactions.unshift({id:Date.now(),date:new Date().toISOString(),type:'deposit',amount:amt,note});pushHistory(S.cashBalance);save();updateUI();clearDep();showSuccess(amt)}
function clearDep(){DENOMS.forEach(d=>document.getElementById(d.id).value=0);document.getElementById('dNote').value='';document.getElementById('depPreview').textContent='$0.00'}

function upSpend(){const n=parseFloat(document.getElementById('sAmt').value)||0,after=S.cashBalance-Math.round(n*100),el=document.getElementById('spendAfter');el.textContent=fc(Math.max(0,after));el.style.color=after<0?'var(--ruby)':'var(--ink)'}
function doSpend(){const amt=Math.round((parseFloat(document.getElementById('sAmt').value)||0)*100),note=document.getElementById('sNote').value.trim(),cat=document.getElementById('sCat').value;if(!amt||amt<=0){alert('How much did you spend?');return}if(!note){alert('What did you buy?');return}if(amt>S.cashBalance&&!confirm("You don't have enough cash! Record it anyway?"))return;S.cashBalance=Math.max(0,S.cashBalance-amt);S.transactions.unshift({id:Date.now(),date:new Date().toISOString(),type:'spend',amount:amt,note,cat});pushHistory(S.cashBalance);save();updateUI();document.getElementById('sAmt').value='';document.getElementById('sNote').value='';upSpend();alert('Recorded! '+note+' — '+fc(amt))}

const GCT=['gct0','gct1','gct2','gct3','gct4'];
function gcSum(){return S.giftCards.reduce((s,g)=>s+g.balance,0)}
function addGc(){const store=document.getElementById('gcStore').value.trim(),bal=Math.round(parseFloat(document.getElementById('gcBal').value)*100),note=document.getElementById('gcNote').value.trim();if(!store){alert('What store is the gift card for?');return}if(!bal||bal<=0){alert('Enter the balance on the card!');return}S.giftCards.push({id:Date.now(),store,balance:bal,originalBalance:bal,note,addedDate:new Date().toISOString(),txns:[]});save();updateUI();['gcStore','gcBal','gcNote'].forEach(id=>document.getElementById(id).value='');renderGcs()}
function renderGcs(){const el=document.getElementById('gcList');if(!S.giftCards.length){el.innerHTML='<div class="empty"><div class="empty-chip">'+I.gift2+'</div><div class="et">No gift cards yet</div></div>';return}el.innerHTML=S.giftCards.map((gc,i)=>{const pct=Math.round((gc.balance/gc.originalBalance)*100);return '<div class="gcard '+GCT[i%GCT.length]+'"><div class="gcard-shine"></div><div class="gc-store">'+esc(gc.store)+'</div>'+(gc.note?'<div class="gc-note">'+esc(gc.note)+'</div>':'')+'<div class="gc-brow"><div class="gc-bal">'+fc(gc.balance)+'</div><div class="gc-orig">'+pct+'% of '+fc(gc.originalBalance)+' left</div></div><div class="gc-acts"><button class="gcb" onclick="openGcModal('+gc.id+')">'+I.card+' Use Card</button><button class="gcb gcb-del" onclick="removeGc('+gc.id+')">'+I.trash+'</button></div></div>'}).join('')}
function openGcModal(id){activeGcId=id;const gc=S.giftCards.find(g=>g.id===id);document.getElementById('gcModalTitle').innerHTML='<div class="icon-chip amber">'+I.card+'</div>Use '+esc(gc.store)+' ('+fc(gc.balance)+' left)';document.getElementById('gcUseAmt').value='';document.getElementById('gcUseNote').value='';document.getElementById('gcModal').classList.add('open')}
function closeGcModal(){document.getElementById('gcModal').classList.remove('open');activeGcId=null}
function confirmGcUse(){const amt=Math.round(parseFloat(document.getElementById('gcUseAmt').value)*100),note=document.getElementById('gcUseNote').value.trim()||'Purchase',gc=S.giftCards.find(g=>g.id===activeGcId);if(!gc)return;if(!amt||amt<=0){alert('Enter an amount!');return}if(amt>gc.balance){alert('You only have '+fc(gc.balance)+' left!');return}gc.balance-=amt;gc.txns.push({date:new Date().toISOString(),amount:amt,note});save();updateUI();renderGcs();closeGcModal();alert('Used '+fc(amt)+' from your '+gc.store+' card!')}
function removeGc(id){if(!confirm('Remove this gift card?'))return;S.giftCards=S.giftCards.filter(g=>g.id!==id);save();updateUI();renderGcs()}

function updateStock(){const raw=parseFloat(document.getElementById('stockInput').value);if(isNaN(raw)||raw<0){alert('Enter a valid dollar amount!');return}const oldVal=S.investments.stockBalance,newVal=Math.round(raw*100),isC=oldVal>0&&newVal!==oldVal;S.investments.stockBalance=newVal;S.investments.stockUpdated=new Date().toISOString();S.transactions.unshift({id:Date.now(),date:new Date().toISOString(),type:'invest-stock',note:isC?'Stock balance corrected':'Stock portfolio balance updated',value:fc(newVal),correction:isC,prevValue:isC?fc(oldVal):null});document.getElementById('stockInput').value='';save();renderInvest();renderHomeInvest();renderHistory()}
function updateBtc(){const raw=parseFloat(document.getElementById('btcInput').value);if(isNaN(raw)||raw<0){alert('Enter a valid BTC amount!');return}const oldAmt=S.investments.btcAmount,isC=oldAmt>0&&raw!==oldAmt;S.investments.btcAmount=raw;S.investments.btcUpdated=new Date().toISOString();S.transactions.unshift({id:Date.now(),date:new Date().toISOString(),type:'invest-btc',note:isC?'Bitcoin amount corrected':'Bitcoin added to tracker',value:raw+' BTC',correction:isC,prevValue:isC?oldAmt+' BTC':null});document.getElementById('btcInput').value='';save();renderHistory();fetchBtc()}

async function fetchBtc(){
  const txt=document.getElementById('btcPriceTxt');if(txt)txt.textContent='Loading live BTC price...';
  const apis=[
    async()=>{const r=await fetch('https://api.coinbase.com/v2/prices/BTC-USD/spot');if(!r.ok)throw 0;const d=await r.json();const p=parseFloat(d?.data?.amount);if(!p||p<=0)throw 0;return p},
    async()=>{const r=await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd');if(!r.ok)throw 0;const d=await r.json();const p=+d?.bitcoin?.usd;if(!p||p<=0)throw 0;return p},
    async()=>{const r=await fetch('https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT');if(!r.ok)throw 0;const d=await r.json();const p=parseFloat(d?.price);if(!p||p<=0)throw 0;return p},
    async()=>{const r=await fetch('https://api.kraken.com/0/public/Ticker?pair=XBTUSD');if(!r.ok)throw 0;const d=await r.json();const p=parseFloat(d?.result?.XXBTZUSD?.c?.[0]);if(!p||p<=0)throw 0;return p},
  ];
  let price=null;
  for(const api of apis){try{price=await new Promise((res,rej)=>{const t=setTimeout(()=>rej(0),7000);api().then(p=>{clearTimeout(t);res(p)}).catch(e=>{clearTimeout(t);rej(e)})});if(price&&price>0)break}catch(e){price=null}}
  if(price&&price>0){S.investments.cachedBtcPrice=price;S.investments.btcPriceAt=new Date().toISOString();save()}
  renderInvest();renderHomeInvest();
}

function resetInvestments(){if(!confirm('Reset all investment data? Cash and gift cards are NOT affected.'))return;S.investments={stockBalance:0,stockUpdated:null,btcAmount:0,btcUpdated:null,cachedBtcPrice:null,btcPriceAt:null};S.transactions=S.transactions.filter(t=>t.type!=='invest-stock'&&t.type!=='invest-btc');save();renderInvest();renderHomeInvest();renderHistory();alert('Investment data has been reset.')}

function renderInvest(){
  const inv=S.investments;
  document.getElementById('stockDisp').textContent=fc(inv.stockBalance);
  document.getElementById('stockUpd').textContent=inv.stockUpdated?'Last updated: '+fd(inv.stockUpdated):'Not set yet — ask your parent!';
  document.getElementById('stockNudge').style.display=daysSince(inv.stockUpdated)>7?'flex':'none';
  const si=document.getElementById('stockInput');if(si&&!si.value&&inv.stockBalance)si.placeholder=(inv.stockBalance/100).toFixed(2)+' (current)';
  const price=inv.cachedBtcPrice,bv=(inv.btcAmount&&price)?inv.btcAmount*price:0;
  document.getElementById('btcAmtDisp').textContent=inv.btcAmount?inv.btcAmount+' BTC':'0 BTC';
  document.getElementById('btcValDisp').textContent=bv?fu(bv):'$—';
  const bi=document.getElementById('btcInput');if(bi&&!bi.value&&inv.btcAmount)bi.placeholder=inv.btcAmount+' (current)';
  document.getElementById('btcPriceTxt').textContent=price?'1 BTC = '+fu(price)+'  ·  '+fd(inv.btcPriceAt):'Tap Refresh to load live price';
  const tot=(inv.stockBalance/100)+bv;document.getElementById('portTotal').textContent=tot>0?fu(tot):'$0.00';
}

function renderHistory(){const el=document.getElementById('histList');if(!S.transactions.length){el.innerHTML='<div class="empty"><div class="empty-chip">'+I.list+'</div><div class="et">No transactions yet</div></div>';return}el.innerHTML=S.transactions.map(t=>txnHTML(t,true)).join('')}
function deleteTransaction(id){const t=S.transactions.find(x=>x.id===id);if(!t)return;if(!confirm('Remove "'+( t.note||t.type)+'" from history?'))return;S.transactions=S.transactions.filter(x=>x.id!==id);save();renderHistory();renderHomeRecent()}

async function reqNotif(){if(!('Notification'in window)){alert("This browser doesn't support notifications.");return}const p=await Notification.requestPermission();if(p==='granted'){S.settings.notificationsEnabled=true;save();new Notification('Money Vault',{body:"You're set! Tap the bell icon anytime."});alert('Notifications enabled!')}else alert('Notifications blocked. Enable them in your device settings.')}
function sendNotif(){const n=S.settings.childName||'My',gt=gcSum(),body='Cash: '+fc(S.cashBalance)+(gt>0?'  ·  Gift Cards: '+fc(gt):'')+' · Total: '+fc(S.cashBalance+gt);if(!('Notification'in window)){alert(body);return}if(Notification.permission==='granted')new Notification(n+"'s Balance",{body});else if(Notification.permission!=='denied')Notification.requestPermission().then(p=>{if(p==='granted')new Notification(n+"'s Balance",{body})});else alert(n+"'s Balance:\n"+body)}

function clearAll(){if(!confirm('Delete ALL data? Cannot be undone!')||!confirm('Last chance — really delete everything?'))return;localStorage.removeItem(KEY);localStorage.removeItem('moneyVault_v3');S={cashBalance:0,transactions:[],balanceHistory:[],giftCards:[],investments:{stockBalance:0,stockUpdated:null,btcAmount:0,btcUpdated:null,cachedBtcPrice:null,btcPriceAt:null},settings:{childName:'',notificationsEnabled:false}};updateUI();renderGcs();renderHistory();renderInvest();alert('All data cleared.')}

function showSuccess(cents){document.getElementById('scAmt').textContent='+'+fc(cents)+' added to your balance!';const ov=document.getElementById('sov'),sc=document.getElementById('sc');ov.classList.add('on');requestAnimationFrame(()=>requestAnimationFrame(()=>sc.classList.add('show')));const cx=window.innerWidth/2,cy=window.innerHeight/2;['#1a6644','#c8860a','#1a5fa6','#237a52','#bf3b3b'].forEach((c,i)=>{const el=document.createElement('div');el.className='float-dot';el.style.cssText='background:'+c+';left:'+(cx+(i-2)*40+(Math.random()-.5)*20)+'px;top:'+cy+'px;animation-delay:'+(i*70)+'ms';document.body.appendChild(el);setTimeout(()=>el.remove(),2000+i*70)});clearTimeout(successTimer);successTimer=setTimeout(()=>{sc.classList.remove('show');ov.classList.remove('on')},2900)}

document.getElementById('gcModal').addEventListener('click',function(e){if(e.target===this)closeGcModal()});
load();
if(S.settings.childName)document.getElementById('setName').value=S.settings.childName;
updateUI();renderGcs();renderHistory();renderInvest();fetchBtc();
window.addEventListener('resize',()=>{if(document.getElementById('tab-home').classList.contains('active'))drawChart()});
</script>

