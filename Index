<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Money Vault</title>
<link rel="manifest" href="manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --cream:#faf8f3;--white:#fff;
  --forest:#1a6644;--forest-mid:#237a52;--forest-pale:#e6f4ed;--forest-deep:#081f10;
  --amber:#c8860a;--amber-pale:#fef7e7;--amber-bdr:#f8d78a;
  --ruby:#bf3b3b;--ruby-pale:#fdeaea;
  --sky:#1a5fa6;--sky-pale:#e8f1fb;
  --ink:#1c2419;--sage:#5a7060;--border:#e4ebe0;
  --sh-sm:0 2px 10px rgba(26,60,30,.08);
  --sh-lg:0 18px 50px rgba(26,60,30,.18);
  --r-xl:22px;--r-lg:16px;--r-md:12px;--r-sm:8px;
}
html,body{height:100%;font-family:'Outfit',sans-serif;background:var(--cream);color:var(--ink);-webkit-tap-highlight-color:transparent;overscroll-behavior:none}
.svi{display:inline-flex;align-items:center;justify-content:center;flex-shrink:0}
.svi svg{display:block}
.hdr{background:linear-gradient(160deg,#081f10 0%,#1a6644 52%,#237a52 100%);color:#fff;padding:22px 18px 42px;position:relative;overflow:hidden;border-bottom-left-radius:30px;border-bottom-right-radius:30px;}
.hdr::before{content:'';position:absolute;top:-70px;right:-70px;width:240px;height:240px;border:55px solid rgba(255,255,255,.04);border-radius:50%}
.hdr::after{content:'';position:absolute;bottom:-100px;left:-50px;width:280px;height:280px;background:radial-gradient(circle,rgba(46,204,142,.1) 0%,transparent 70%);border-radius:50%}
.hdr-top{display:flex;justify-content:space-between;align-items:center;position:relative;z-index:2}
.hdr-name{font-size:.96em;font-weight:700;opacity:.88;letter-spacing:.2px}
.bell-btn{width:40px;height:40px;border-radius:50%;border:1.5px solid rgba(255,255,255,.22);background:rgba(255,255,255,.1);color:rgba(255,255,255,.9);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;backdrop-filter:blur(4px);}
.bell-btn:active{background:rgba(255,255,255,.25)}
.hdr-bal{text-align:center;margin-top:18px;position:relative;z-index:2}
.hdr-lbl{font-size:.68em;font-weight:600;opacity:.58;text-transform:uppercase;letter-spacing:2px}
.hdr-amt{font-family:'Syne',sans-serif;font-size:3.7em;font-weight:800;line-height:1;letter-spacing:-2px;margin-top:4px}
.hdr-pill{display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.17);border-radius:20px;padding:5px 14px;font-size:.72em;font-weight:600;margin-top:12px;backdrop-filter:blur(4px);}
.pulse-dot{width:7px;height:7px;background:#34d399;border-radius:50%;animation:pdot 2s infinite;flex-shrink:0}
@keyframes pdot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
.nav{position:fixed;bottom:0;left:0;right:0;background:var(--white);display:flex;border-top:1px solid var(--border);z-index:100;padding-bottom:env(safe-area-inset-bottom);box-shadow:0 -4px 24px rgba(26,60,30,.08);}
.nb{flex:1;padding:8px 2px;border:none;background:none;cursor:pointer;font-size:.58em;color:var(--sage);display:flex;flex-direction:column;align-items:center;gap:4px;font-family:'Outfit',sans-serif;font-weight:600;transition:color .18s;}
.nb-ico{width:36px;height:36px;border-radius:11px;display:flex;align-items:center;justify-content:center;background:transparent;transition:background .18s,transform .18s;color:inherit;}
.nb.active{color:var(--forest)}
.nb.active .nb-ico{background:var(--forest-pale);transform:scale(1.08)}
.content{padding:0 0 96px}
.tab{display:none}.tab.active{display:block}
.card{background:var(--white);border-radius:var(--r-xl);padding:20px;margin:14px 14px 0;box-shadow:var(--sh-sm);border:1px solid var(--border);overflow:hidden}
.ctitle{font-family:'Syne',sans-serif;font-size:.93em;font-weight:700;color:var(--ink);margin-bottom:14px;display:flex;align-items:center;gap:9px;}
.icon-chip{width:30px;height:30px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.icon-chip.green{background:var(--forest-pale);color:var(--forest)}
.icon-chip.amber{background:var(--amber-pale);color:var(--amber)}
.icon-chip.sky{background:var(--sky-pale);color:var(--sky)}
.icon-chip.ruby{background:var(--ruby-pale);color:var(--ruby)}
.icon-chip.muted{background:#f0f2f0;color:var(--sage)}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:14px 14px 0}
.sp{background:var(--white);border:1px solid var(--border);border-radius:var(--r-xl);padding:16px 16px 14px;box-shadow:var(--sh-sm)}
.sp-icon{width:36px;height:36px;border-radius:11px;display:flex;align-items:center;justify-content:center;margin-bottom:10px}
.sp-icon.green{background:var(--forest-pale);color:var(--forest)}
.sp-icon.amber{background:var(--amber-pale);color:var(--amber)}
.sp .sl{font-size:.68em;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--sage)}
.sp .sv{font-family:'Syne',sans-serif;font-size:1.5em;font-weight:800;margin-top:4px}
.sp.green .sv{color:var(--forest)}.sp.amber .sv{color:var(--amber)}
.total-bar{background:linear-gradient(135deg,var(--sky),#1e4d8c);color:white;border-radius:var(--r-xl);padding:16px 20px;margin:10px 14px 0;display:flex;justify-content:space-between;align-items:center;box-shadow:0 6px 20px rgba(26,95,166,.22);}
.total-bar .tl{font-size:.78em;font-weight:600;opacity:.85;display:flex;align-items:center;gap:7px}
.total-bar .tv{font-family:'Syne',sans-serif;font-size:1.8em;font-weight:800}
.chart-wrap{background:var(--white);border-radius:var(--r-xl);padding:18px 18px 12px;margin:14px 14px 0;box-shadow:var(--sh-sm);border:1px solid var(--border)}
.chart-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.chart-ttl{font-family:'Syne',sans-serif;font-size:.9em;font-weight:700;display:flex;align-items:center;gap:8px;color:var(--ink)}
.chart-badge{background:var(--forest-pale);color:var(--forest);border-radius:20px;padding:4px 11px;font-size:.72em;font-weight:700}
#bchart{width:100%;height:130px;display:block;border-radius:var(--r-md);background:var(--cream)}
.chart-sub{font-size:.7em;color:var(--sage);font-weight:600;text-align:center;margin-top:8px}
.field{margin-bottom:14px}
.field label{display:block;font-size:.73em;font-weight:700;color:var(--sage);text-transform:uppercase;letter-spacing:.8px;margin-bottom:7px}
.field input,.field select{width:100%;padding:13px 16px;border:2px solid var(--border);border-radius:var(--r-md);font-size:1em;font-family:'Outfit',sans-serif;font-weight:600;color:var(--ink);background:var(--white);transition:border-color .18s,box-shadow .18s;-webkit-appearance:none;outline:none;}
.field input:focus,.field select:focus{border-color:var(--forest);box-shadow:0 0 0 3px rgba(26,102,68,.1)}
.field.big input{font-size:2em;font-weight:800;font-family:'Syne',sans-serif;text-align:center;letter-spacing:-.5px}
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:16px;width:100%;overflow:hidden;}
.ctile{background:var(--cream);border:1.5px solid var(--border);border-radius:var(--r-md);padding:9px 8px;display:flex;align-items:center;gap:7px;transition:border-color .18s;min-width:0;overflow:hidden;}
.ctile:focus-within{border-color:var(--forest)}
.ctile.full{grid-column:1/-1}
.dchip{flex-shrink:0;font-family:'Syne',sans-serif;font-weight:800;display:flex;align-items:center;justify-content:center;line-height:1;letter-spacing:-.5px;}
.dchip.coin{width:34px;height:34px;border-radius:50%;font-size:.65em;border:2px solid}
.dchip.bill{width:38px;height:22px;border-radius:5px;font-size:.6em;border:1.5px solid}
.dc-penny{background:#fdf3e7;color:#a05a20;border-color:#d4956b}
.dc-nickel{background:#f0f2f4;color:#5a6570;border-color:#9faab0}
.dc-dime{background:#f2f4f6;color:#4a5568;border-color:#8a9bb0}
.dc-quart{background:#fafaf0;color:#7a7020;border-color:#c8b840}
.dc-dcoin{background:#fef9e7;color:#a08010;border-color:#d4b040}
.db-1{background:#e8f5ee;color:#1a6644;border-color:#7dc8a4}
.db-5{background:#eaf0f8;color:#1a5fa6;border-color:#7aaad4}
.db-10{background:#f0eafa;color:#5a2d91;border-color:#a880d4}
.db-20{background:#fef3e8;color:#c86a0a;border-color:#e8a870}
.db-50{background:#fde8e8;color:#a02020;border-color:#e08888}
.db-100{background:#1a6644;color:#fff;border-color:#1a6644}
.cmeta{flex:1;min-width:0;overflow:hidden}
.cmeta .cn{font-weight:700;font-size:.78em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cmeta .cv{font-size:.64em;color:var(--sage);font-weight:600;margin-top:1px}
.ctile input{width:44px;min-width:44px;max-width:44px;padding:7px 2px;border:2px solid var(--border);border-radius:var(--r-sm);text-align:center;font-size:.9em;font-weight:800;font-family:'Outfit',sans-serif;color:var(--ink);background:var(--white);flex-shrink:0;outline:none;transition:border-color .18s;-webkit-appearance:none;}
.ctile input:focus{border-color:var(--forest)}
.dep-box{background:linear-gradient(135deg,#081f10,#1a6644);color:white;border-radius:var(--r-lg);padding:20px;text-align:center;margin-bottom:16px;box-shadow:0 6px 20px rgba(26,102,68,.28);}
.dep-box .dl{font-size:.68em;opacity:.7;text-transform:uppercase;letter-spacing:1.8px;font-weight:700}
.dep-box .da{font-family:'Syne',sans-serif;font-size:3.1em;font-weight:800;margin-top:4px;letter-spacing:-1px}
.btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:15px 20px;border:none;border-radius:var(--r-md);font-size:.93em;font-weight:700;font-family:'Outfit',sans-serif;cursor:pointer;transition:transform .12s,opacity .12s;margin-top:10px;}
.btn:active{transform:scale(.97);opacity:.88}
.btn-f{background:var(--forest);color:white;box-shadow:0 4px 14px rgba(26,102,68,.3)}
.btn-r{background:var(--ruby);color:white;box-shadow:0 4px 14px rgba(191,59,59,.28)}
.btn-a{background:var(--amber);color:white;box-shadow:0 4px 14px rgba(200,134,10,.28)}
.btn-g{background:var(--cream);color:var(--ink);border:1.5px solid var(--border);box-shadow:none}
.spend-prev{background:var(--amber-pale);border:1.5px solid var(--amber-bdr);border-radius:var(--r-lg);padding:14px;text-align:center;margin-top:4px}
.spend-prev .afl{font-size:.7em;font-weight:700;color:var(--amber);text-transform:uppercase;letter-spacing:.8px;display:flex;align-items:center;justify-content:center;gap:5px}
.spend-prev .afa{font-family:'Syne',sans-serif;font-size:2.2em;font-weight:800;color:var(--ink);margin-top:3px}
.txn{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--cream)}
.txn:last-child{border-bottom:none}
.txn-ico{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.txn-ico.d{background:var(--forest-pale);color:var(--forest)}
.txn-ico.s{background:var(--ruby-pale);color:var(--ruby)}
.txn-ico.inv{background:var(--sky-pale);color:var(--sky)}
.txn-body{flex:1;min-width:0}
.txn-note{font-weight:700;font-size:.9em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.txn-cat{font-size:.7em;color:var(--sky);font-weight:600;margin-top:1px}
.txn-date{font-size:.67em;color:var(--sage);margin-top:2px;font-weight:500}
.txn-amt{font-family:'Syne',sans-serif;font-weight:800;font-size:.95em;flex-shrink:0}
.txn-amt.p{color:var(--forest)}.txn-amt.n{color:var(--ruby)}
.txn-del-btn{display:flex;align-items:center;gap:4px;margin-top:5px;background:none;border:1px solid var(--border);border-radius:6px;padding:3px 8px;font-size:.68em;font-weight:700;color:var(--sage);cursor:pointer;font-family:'Outfit',sans-serif;transition:background .15s,color .15s;}
.txn-del-btn:active{background:var(--ruby-pale);color:var(--ruby);border-color:var(--ruby)}
.gcard{border-radius:var(--r-xl);padding:20px;margin-bottom:12px;color:white;position:relative;overflow:hidden}
.gcard-shine{position:absolute;top:-30%;right:-10%;width:60%;height:180%;background:linear-gradient(105deg,transparent 40%,rgba(255,255,255,.07) 50%,transparent 60%);pointer-events:none}
.gc-store{font-family:'Syne',sans-serif;font-size:1.15em;font-weight:800}
.gc-note{font-size:.77em;opacity:.72;margin-top:3px;font-weight:500}
.gc-brow{display:flex;align-items:flex-end;justify-content:space-between;margin-top:18px}
.gc-bal{font-family:'Syne',sans-serif;font-size:2.2em;font-weight:800}
.gc-orig{font-size:.7em;opacity:.65;font-weight:500;margin-bottom:4px}
.gc-acts{display:flex;gap:8px;margin-top:14px}
.gcb{flex:1;padding:10px 8px;border:none;border-radius:10px;background:rgba(255,255,255,.2);color:white;font-weight:700;font-family:'Outfit',sans-serif;font-size:.82em;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px}
.gcb-del{flex:none;padding:10px 14px;background:rgba(0,0,0,.18)}
.gct0{background:linear-gradient(145deg,#1a5c3a,#0f3520)}
.gct1{background:linear-gradient(145deg,#1a4d8c,#0f2e5a)}
.gct2{background:linear-gradient(145deg,#8c3a1a,#5a2010)}
.gct3{background:linear-gradient(145deg,#6b3a8c,#3f1f5a)}
.gct4{background:linear-gradient(145deg,#8c6a1a,#5a420e)}
.isect{background:var(--white);border-radius:var(--r-xl);padding:20px;margin:14px 14px 0;border:1px solid var(--border);box-shadow:var(--sh-sm)}
.isect-ttl{font-family:'Syne',sans-serif;font-size:.95em;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:9px}
.stock-disp{background:linear-gradient(135deg,#1a6644,#237a52);color:white;border-radius:var(--r-lg);padding:20px;text-align:center;margin-bottom:14px}
.sd-lbl{font-size:.67em;opacity:.7;text-transform:uppercase;letter-spacing:1.8px;font-weight:700}
.sd-val{font-family:'Syne',sans-serif;font-size:2.8em;font-weight:800;margin-top:4px;letter-spacing:-1px}
.sd-upd{display:flex;align-items:center;justify-content:center;gap:5px;font-size:.7em;opacity:.65;margin-top:8px;font-weight:500}
.stock-nudge{background:var(--amber-pale);border:1.5px solid var(--amber-bdr);border-radius:var(--r-md);padding:13px 14px;margin-bottom:12px;font-size:.8em;font-weight:600;color:#7a4e08;display:flex;align-items:flex-start;gap:10px;line-height:1.5;}
.btc-disp{background:linear-gradient(135deg,#d97706,#b45309);color:white;border-radius:var(--r-lg);padding:18px;margin-bottom:14px}
.btc-row{display:flex;justify-content:space-between;align-items:flex-start}
.btc-lbl{font-size:.68em;opacity:.75;text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:4px}
.btc-val{font-family:'Syne',sans-serif;font-size:1.9em;font-weight:800}
.btc-amt-txt{font-family:'Syne',sans-serif;font-size:1.3em;font-weight:800}
.btc-btm{display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.2)}
.btc-sub{font-size:.73em;opacity:.8;font-weight:600}
.btc-ref{background:rgba(255,255,255,.22);border:none;border-radius:20px;padding:6px 13px;color:white;font-size:.73em;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif;display:flex;align-items:center;gap:5px;}
.ptotal{background:linear-gradient(135deg,var(--sky),#1e4d8c);color:white;border-radius:var(--r-xl);padding:18px 20px;margin:14px 14px 0;text-align:center;box-shadow:0 6px 20px rgba(26,95,166,.22)}
.pt-lbl{font-size:.68em;opacity:.78;text-transform:uppercase;letter-spacing:1.8px;font-weight:700}
.pt-val{font-family:'Syne',sans-serif;font-size:2.5em;font-weight:800;margin-top:4px;letter-spacing:-.5px}
.infobox{background:var(--sky-pale);border-radius:var(--r-md);padding:13px 15px;font-size:.79em;font-weight:600;color:#1a3d6b;line-height:1.55;margin:14px 14px 0;display:flex;gap:10px;align-items:flex-start}
.infobox-icon{flex-shrink:0;color:var(--sky);margin-top:1px}
.inv-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--cream)}
.inv-row:last-child{border-bottom:none}
.inv-row-left{display:flex;align-items:center;gap:8px;font-weight:600;font-size:.9em}
.inv-row-chip{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.inv-row-chip.green{background:var(--forest-pale);color:var(--forest)}
.inv-row-chip.amber{background:var(--amber-pale);color:var(--amber)}
.inv-total-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;font-weight:800;font-family:'Syne',sans-serif}
.empty{text-align:center;padding:32px 16px;color:var(--sage)}
.empty-chip{width:52px;height:52px;border-radius:16px;background:var(--cream);display:flex;align-items:center;justify-content:center;margin:0 auto 10px;color:var(--sage)}
.empty .et{font-weight:600;font-size:.88em}
.mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:flex-end;backdrop-filter:blur(2px)}
.mbg.open{display:flex}
.msheet{background:var(--white);border-radius:26px 26px 0 0;padding:24px 20px 40px;width:100%;max-height:85vh;overflow-y:auto}
.mhandle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px}
#sov{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:500;pointer-events:none;background:rgba(8,31,16,0);transition:background .3s}
#sov.on{background:rgba(8,31,16,.38);pointer-events:auto}
.sc{background:white;border-radius:30px;padding:40px 50px;text-align:center;box-shadow:var(--sh-lg);position:relative;transform:scale(0) rotate(-10deg);transition:transform .48s cubic-bezier(.34,1.65,.64,1)}
.sc.show{transform:scale(1) rotate(0deg)}
.sc-ring{position:absolute;top:50%;left:50%;width:80px;height:80px;border-radius:50%;border:3px solid rgba(26,102,68,.4);transform:translate(-50%,-50%);pointer-events:none}
.sc-ring.r1{animation:ro .85s ease-out .08s both}
.sc-ring.r2{animation:ro .85s ease-out .22s both}
.sc-ring.r3{animation:ro .85s ease-out .38s both}
@keyframes ro{from{transform:translate(-50%,-50%) scale(1);opacity:.7}to{transform:translate(-50%,-50%) scale(5.5);opacity:0}}
.sc-check{width:72px;height:72px;border-radius:50%;background:var(--forest-pale);display:flex;align-items:center;justify-content:center;margin:0 auto;color:var(--forest);animation:bi .5s cubic-bezier(.34,1.56,.64,1) .28s both}
@keyframes bi{from{transform:scale(0)}to{transform:scale(1)}}
.sc-ttl{font-family:'Syne',sans-serif;font-size:1.5em;font-weight:800;color:var(--forest);margin-top:12px}
.sc-amt{font-size:.95em;color:var(--sage);font-weight:600;margin-top:6px}
.float-dot{position:fixed;width:12px;height:12px;border-radius:50%;pointer-events:none;z-index:501;animation:fup 1.8s ease-out forwards}
@keyframes fup{0%{transform:translateY(0) scale(1);opacity:1}60%{opacity:1}100%{transform:translateY(-180px) scale(.3);opacity:0}}
.srow{padding:16px 0;border-bottom:1px solid var(--cream)}
.srow:last-child{border-bottom:none}
.slbl{font-weight:700;font-size:.9em;margin-bottom:3px;display:flex;align-items:center;gap:7px}
.ssub{font-size:.76em;color:var(--sage);margin-bottom:10px;line-height:1.5;font-weight:500}
.danger{color:var(--ruby)}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-top">
    <span class="hdr-name" id="hdrName">My Money Vault</span>
    <button class="bell-btn" onclick="sendNotif()">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </button>
  </div>
  <div class="hdr-bal">
    <div class="hdr-lbl">Cash Balance</div>
    <div class="hdr-amt" id="hdrAmt">$0.00</div>
